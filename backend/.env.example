# Server
PORT=3000
NODE_ENV=development

# Database (local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chhotu_genius
DB_USER=postgres
DB_PASSWORD=postgres

# Database (production - Render provides this)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Auth
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS - comma-separated origins (use * for development)
CORS_ORIGIN=*
# CORS_ORIGIN=https://your-admin.onrender.com,https://your-admin.vercel.app

# Firebase Admin SDK (production - paste JSON as single line)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# For development, place firebase-service-account.json in backend/ directory
